# Copy this file to ".env" and fill in the values. ".env" is gitignored —
# never commit secrets. Keep this file in sync with the schema in src/env.js.

# ── Database ──────────────────────────────────────────────────────────────
# Used only by drizzle.config.ts for `npm run db:push` against a local dev DB.
DATABASE_URL="file:./db.sqlite"

# Central users database (accounts, verification tokens, feedback).
# Local file for dev; a Turso URL + auth token in production.
USERS_DATABASE_URL="file:./users.db"
# USERS_DATABASE_AUTH_TOKEN=""

# Turso Platform API — provisions one database per user on signup.
# Leave unset in dev to fall back to local SQLite files.
# TURSO_API_TOKEN=""
# TURSO_ORGANIZATION=""

# ── Auth ──────────────────────────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Base URL for auth callbacks/links, e.g. http://localhost:3000 in dev.
# AUTH_URL=""

# ── AI providers ──────────────────────────────────────────────────────────
# At least one provider key is needed for habit extraction, chat, and insights.
# Groq is the default; AI_PROVIDER/AI_MODEL/AI_BASE_URL override the selection.
GROQ_API_KEY=""
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GOOGLE_GENERATIVE_AI_API_KEY=""
# AI_PROVIDER=""
# AI_MODEL=""
# AI_BASE_URL=""

# OpenRouter — self-hosted instances only. On shared deployments leave these
# unset: each user brings their own key via Settings, and BYO providers
# refuse to save without one.
# AI_PROVIDER="openrouter"
# AI_MODEL="openrouter/auto"
# AI_BASE_URL="https://openrouter.ai/api/v1"
# OPENAI_API_KEY="sk-or-..."

# ── Email (Resend) ────────────────────────────────────────────────────────
# For verification emails and feedback forwarding.
# RESEND_API_KEY=""
# EMAIL_FROM=""
# FEEDBACK_TO=""

# ── Web Push / reminders ──────────────────────────────────────────────────
# Generate a key pair with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY must equal VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Shared secret protecting the /api/cron/reminders endpoint.
CRON_SECRET=""
